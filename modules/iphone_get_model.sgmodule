#!name=iPhone/iPad 直營店庫存檢查 - 獲得機型代碼
#!desc=請用非 Safari 瀏覽器開啟 Apple 官網，出現安全警告時按進階選項繞過警告，再將您要的機型加入購物車，獲得機型代號後即可關閉此模組。若無法繞過警告，請多換幾個瀏覽器試試，部分用戶需試 3~4 種瀏覽器才成功。 v20230921

[Script]
[直營店庫存檢查]獲得機型代碼 = type=http-request,pattern=^https:\/\/www\.apple\.com\/tw\/shop\/buy-(iphone|ipad)\/,script-path=https://kinta.ma/surge/scripts/iphone_get_model.js,script-update-interval=-1

[MITM]
hostname = %APPEND% www.apple.com
