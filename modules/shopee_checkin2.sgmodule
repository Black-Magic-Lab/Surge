[蝦皮]取得簽到資訊 = type=http-request, pattern=^https:\/\/games-dailycheckin\.shopee\.tw\/mkt\/coins\/api\/v2\/checkin_new$, script-path=https://kinta.ma/surge/scripts/shopee_get_checkin.js

[MITM]
